<Window x:Class="Gastrox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Gastrox.Views"
        Title="Gastrox – Skladový software"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Boční menu -->
        <Border Grid.Column="0" Background="#202020">
            <StackPanel Margin="16">
                <TextBlock Text="GASTROX" Foreground="White" FontSize="22" FontWeight="Bold" Margin="8,16,8,24"/>

                <Button Content="Dashboard"   Style="{StaticResource MenuButton}" Click="Dashboard_Click"/>
                <Button Content="Sklad"       Style="{StaticResource MenuButton}" Click="Sklad_Click"/>
                <Button Content="Příjemky"    Style="{StaticResource MenuButton}" Click="Prijemky_Click"/>
                <Button Content="Výdejky"     Style="{StaticResource MenuButton}" Click="Vydejky_Click"/>
                <Button Content="Inventury"   Style="{StaticResource MenuButton}" Click="Inventury_Click"/>
                <Button Content="Reporty"     Style="{StaticResource MenuButton}" Click="Reporty_Click"/>
            </StackPanel>
        </Border>

        <!-- Hlavní obsah -->
        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="24"/>
    </Grid>
</Window>
