<Application x:Class="Gastrox.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Gastrox.Converters"
             xmlns:beh="clr-namespace:Gastrox.Behaviors"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVisConv"/>
        <conv:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisConv"/>

        <!-- Styl pro numerické TextBoxy: výběr celého obsahu při focusu
             (aby uživatel mohl ihned psát přes 0,00) a zaměnitelnost . / , -->
        <Style x:Key="NumericTextBox" TargetType="TextBox">
            <Setter Property="beh:NumericBoxBehavior.IsNumeric" Value="True"/>
        </Style>
    </Application.Resources>
</Application>
