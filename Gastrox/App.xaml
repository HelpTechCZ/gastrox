<Application x:Class="Gastrox.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Gastrox.Converters"
             xmlns:beh="clr-namespace:Gastrox.Behaviors"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVisConv"/>
        <conv:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisConv"/>

        <!-- Styl pro numerické TextBoxy: výběr celého obsahu při focusu
             (aby uživatel mohl ihned psát přes 0,00) a zaměnitelnost . / , -->
        <Style x:Key="NumericTextBox" TargetType="TextBox">
            <Setter Property="beh:NumericBoxBehavior.IsNumeric" Value="True"/>
        </Style>

        <!-- Read-only buňky DataGridu: nelze editovat, přeskočit tabulátorem,
             nevysvítí se modře → uživatel okamžitě vidí, co je editovatelné. -->
        <Style x:Key="ReadOnlyCellStyle" TargetType="DataGridCell">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#333"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
