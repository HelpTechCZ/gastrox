<UserControl x:Class="Gastrox.Views.UzaverkaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13" Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:UzaverkaViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>
        <Style x:Key="NumericCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hlavička -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Uzávěrka skladu" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="Aktuální stav všech skladových karet – vygenerujte PDF pro archivaci."
                       Foreground="#666" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Přehled karet -->
        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16">
            <DataGrid ItemsSource="{Binding Karty}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="34"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Název" Binding="{Binding Nazev}" Width="2*"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Kategorie" Binding="{Binding Kategorie}" Width="*"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Stav" Binding="{Binding StavSJednotkou}" Width="*"
                                        ElementStyle="{StaticResource NumericCell}"/>
                    <DataGridTextColumn Header="Nákup za j." Binding="{Binding NakupniCenaZaJednotkuBezDPH, StringFormat={}{0:N2} Kč}" Width="*"
                                        ElementStyle="{StaticResource NumericCell}"/>
                    <DataGridTextColumn Header="Nákup celkem" Binding="{Binding HodnotaNakupBezDPH, StringFormat={}{0:N2} Kč}" Width="*"
                                        ElementStyle="{StaticResource NumericCell}"/>
                    <DataGridTextColumn Header="Prodej za j." Binding="{Binding ProdejniCenaZaJednotkuSDPH, StringFormat={}{0:N2} Kč}" Width="*"
                                        ElementStyle="{StaticResource NumericCell}"/>
                    <DataGridTextColumn Header="Prodej celkem" Binding="{Binding HodnotaProdejSDPH, StringFormat={}{0:N2} Kč}" Width="*"
                                        ElementStyle="{StaticResource NumericCell}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer se souhrnem a tlačítkem -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#F5F9FF" CornerRadius="8" Padding="14,8" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Položek: " Foreground="#666"/>
                        <TextBlock Text="{Binding PocetKaret}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Background="#F5F9FF" CornerRadius="8" Padding="14,8" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Nákup: " Foreground="#666"/>
                        <TextBlock Text="{Binding CelkemNakupBezDph, StringFormat={}{0:N2} Kč}" FontWeight="SemiBold" Foreground="#0078D4"/>
                    </StackPanel>
                </Border>
                <Border Background="#F4FBF4" CornerRadius="8" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Prodej: " Foreground="#666"/>
                        <TextBlock Text="{Binding CelkemProdejSDph, StringFormat={}{0:N2} Kč}" FontWeight="SemiBold" Foreground="#107C10"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button Grid.Column="1" Content="📄 Generovat PDF uzávěrku"
                    Command="{Binding GenerovatPdfCommand}"
                    Padding="24,10" Background="#0078D4" Foreground="White"
                    BorderThickness="0" FontWeight="SemiBold" FontSize="14"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</UserControl>
