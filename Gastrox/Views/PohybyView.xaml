<UserControl x:Class="Gastrox.Views.PohybyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13"
             Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:PohybyViewModel />
    </UserControl.DataContext>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Pohyby" FontSize="24" FontWeight="SemiBold"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Sklad:" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#666"/>
                <ComboBox ItemsSource="{Binding Sklady}"
                          SelectedItem="{Binding VybranySklad}"
                          DisplayMemberPath="Nazev"
                          MinWidth="180" Padding="8,6"
                          ToolTip="Prázdný výběr = všechny sklady"/>
                <Button Content="✕" Margin="4,0,0,0" Padding="8,4"
                        ToolTip="Zrušit filtr skladu"
                        Click="VymazatFiltr_Click"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent" Padding="0">

            <!-- ========== PŘÍJEMKY ========== -->
            <TabItem Header="📥 Příjemky" Padding="12,6">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Seznam příjemek -->
                    <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="0">
                        <DataGrid ItemsSource="{Binding Prijemky}"
                                  SelectedItem="{Binding VybranaPrijemka}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  RowHeight="32"
                                  ColumnHeaderHeight="40"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Resources>
                                <Style x:Key="CellText" TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="Margin" Value="2,0,0,0"/>
                                </Style>
                                <Style x:Key="NumericCell" TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Číslo dokladu" Binding="{Binding CisloDokladu}" Width="140"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Datum" Binding="{Binding DatumPrijeti, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Dodavatel" Binding="{Binding Dodavatel}" Width="*"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Č. faktury" Binding="{Binding CisloFaktury}" Width="120"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Sklad" Binding="{Binding SkladNazev}" Width="120"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Celkem bez DPH" Binding="{Binding CelkemBezDPH, StringFormat=N2}" Width="130"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="Celkem s DPH" Binding="{Binding CelkemSDPH, StringFormat=N2}" Width="130"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Oddělovač -->
                    <TextBlock Grid.Row="1" Text="Řádky příjemky" FontWeight="SemiBold" Margin="0,10,0,6"
                               Visibility="{Binding MaPrijemkaRadky, Converter={StaticResource BoolToVisConv}}"/>

                    <!-- Detail řádků příjemky -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="0"
                            Visibility="{Binding MaPrijemkaRadky, Converter={StaticResource BoolToVisConv}}">
                        <DataGrid ItemsSource="{Binding PrijemkaRadky}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  RowHeight="28"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Resources>
                                <Style x:Key="CellText" TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="Margin" Value="2,0,0,0"/>
                                </Style>
                                <Style x:Key="NumericCell" TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Zboží" Binding="{Binding NazevZbozi}" Width="*"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Balení" Binding="{Binding PocetBaleni, StringFormat=N2}" Width="80"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="× Koef." Binding="{Binding KoeficientPrepoctu, StringFormat=N2}" Width="80"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="= EJ" Binding="{Binding MnozstviEvidencni, StringFormat=N2}" Width="80"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="Cena/bal." Binding="{Binding NakupniCenaBezDPH, StringFormat=N2}" Width="100"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="DPH %" Binding="{Binding SazbaDPH, StringFormat=N0}" Width="60"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="Celkem bez DPH" Binding="{Binding CelkemBezDPH, StringFormat=N2}" Width="120"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="Celkem s DPH" Binding="{Binding CelkemSDPH, StringFormat=N2}" Width="120"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Tisk PDF + Excel -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="📄 Tisk PDF" Padding="18,8"
                                Command="{Binding TisknoutPrijemkuCommand}"
                                Background="#0078D4" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                ToolTip="Vygenerovat PDF pro vybranou příjemku"/>
                        <Button Content="📊 Export Excel" Padding="18,8" Margin="8,0,0,0"
                                Command="{Binding ExportPrijemkyExcelCommand}"
                                Background="#107C10" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                ToolTip="Exportovat všechny příjemky do .xlsx"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== VÝDEJKY ========== -->
            <TabItem Header="📤 Výdejky" Padding="12,6">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Seznam výdejek -->
                    <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="0">
                        <DataGrid ItemsSource="{Binding Vydejky}"
                                  SelectedItem="{Binding VybranaVydejka}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  RowHeight="32"
                                  ColumnHeaderHeight="40"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Resources>
                                <Style x:Key="CellText" TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="Margin" Value="2,0,0,0"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Číslo dokladu" Binding="{Binding CisloDokladu}" Width="140"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Datum" Binding="{Binding DatumVydeje, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Středisko" Binding="{Binding StrediskoLabel}" Width="100"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Typ výdeje" Binding="{Binding TypVydejeLabel}" Width="160"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Sklad" Binding="{Binding SkladNazev}" Width="120"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Poznámka" Binding="{Binding Poznamka}" Width="*"
                                                    ElementStyle="{StaticResource CellText}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Oddělovač -->
                    <TextBlock Grid.Row="1" Text="Řádky výdejky" FontWeight="SemiBold" Margin="0,10,0,6"
                               Visibility="{Binding MaVydejkaRadky, Converter={StaticResource BoolToVisConv}}"/>

                    <!-- Detail řádků výdejky -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="0"
                            Visibility="{Binding MaVydejkaRadky, Converter={StaticResource BoolToVisConv}}">
                        <DataGrid ItemsSource="{Binding VydejkaRadky}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  RowHeight="28"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Resources>
                                <Style x:Key="CellText" TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="Margin" Value="2,0,0,0"/>
                                </Style>
                                <Style x:Key="NumericCell" TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Zboží" Binding="{Binding NazevZbozi}" Width="*"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Množství (EJ)" Binding="{Binding MnozstviEvidencni, StringFormat=N2}" Width="110"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="Balení" Binding="{Binding PocetBaleniInfo, StringFormat=N2}" Width="80"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                                <DataGridTextColumn Header="Nákup. cena" Binding="{Binding NakupniCenaBezDPH, StringFormat=N2}" Width="110"
                                                    ElementStyle="{StaticResource NumericCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Tisk PDF + Excel -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="📄 Tisk PDF" Padding="18,8"
                                Command="{Binding TisknoutVydejkuCommand}"
                                Background="#0078D4" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                ToolTip="Vygenerovat PDF pro vybranou výdejku"/>
                        <Button Content="📊 Export Excel" Padding="18,8" Margin="8,0,0,0"
                                Command="{Binding ExportVydejkyExcelCommand}"
                                Background="#107C10" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                ToolTip="Exportovat všechny výdejky do .xlsx"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== PŘEVODKY ========== -->
            <TabItem Header="🔀 Převody" Padding="12,6">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="0">
                        <DataGrid ItemsSource="{Binding Prevodky}"
                                  SelectedItem="{Binding VybranaPrevodka}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  RowHeight="32"
                                  ColumnHeaderHeight="40"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Resources>
                                <Style x:Key="CellText" TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="Margin" Value="2,0,0,0"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Číslo dokladu" Binding="{Binding CisloDokladu}" Width="140"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Datum" Binding="{Binding DatumPrevodu, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Ze skladu" Binding="{Binding SkladZdrojNazev}" Width="160"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Do skladu" Binding="{Binding SkladCilNazev}" Width="160"
                                                    ElementStyle="{StaticResource CellText}"/>
                                <DataGridTextColumn Header="Poznámka" Binding="{Binding Poznamka}" Width="*"
                                                    ElementStyle="{StaticResource CellText}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Tisk PDF -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="📄 Tisk PDF" Padding="18,8"
                                Command="{Binding TisknoutPrevodkuCommand}"
                                Background="#0078D4" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                ToolTip="Vygenerovat PDF pro vybranou převodku"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
