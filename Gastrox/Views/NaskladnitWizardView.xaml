<UserControl x:Class="Gastrox.Views.NaskladnitWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13" Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:NaskladnitWizardViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stepper -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Naskladnit zboží" FontSize="24" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="① Doklad" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="① Doklad" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}"/>
                <TextBlock Text="② Položky" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="② Položky" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}"/>
                <TextBlock Text="③ Souhrn" Foreground="#888"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="③ Souhrn" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="24">
            <Grid>
                <!-- Krok 1 – hlavička -->
                <StackPanel Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Údaje o dokladu" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Číslo dokladu"/>
                            <TextBox Text="{Binding CisloDokladu, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" Padding="8,6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Datum přijetí"/>
                            <DatePicker SelectedDate="{Binding DatumPrijeti}" Margin="0,4,0,12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Dodavatel"/>
                    <TextBox Text="{Binding Dodavatel, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" Padding="8,6"/>

                    <TextBlock Text="Číslo faktury / DL"/>
                    <TextBox Text="{Binding CisloFaktury, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" Padding="8,6"/>

                    <TextBlock Text="Poznámka"/>
                    <TextBox Text="{Binding Poznamka, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"
                             Padding="8,6" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Krok 2 – položky -->
                <Grid Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Položky příjmu" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="+ Přidat řádek" Command="{Binding PridatRadekCommand}"
                                Margin="16,0,0,0" Padding="10,6"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Radky}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="44">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Zboží" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.DostupneZbozi,
                                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding VybraneZbozi, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Nazev"
                                                  IsEditable="True" IsTextSearchEnabled="True"
                                                  TextSearch.TextPath="Nazev"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Balení" Binding="{Binding TypBaleni}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Počet balení"
                                                Binding="{Binding PocetBaleni, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Přepočet"
                                                Binding="{Binding ZobrazeniPrepoctu}"
                                                IsReadOnly="True" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#0066CC"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Cena/bal. bez DPH"
                                                Binding="{Binding NakupniCenaBezDPH, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                Width="*"/>
                            <DataGridTemplateColumn Header="DPH" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DostupneSazby}"
                                                  SelectedItem="{Binding VybranaSazba, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Celkem bez DPH"
                                                Binding="{Binding CelkemBezDPH, StringFormat=N2}"
                                                IsReadOnly="True" Width="*"/>
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="×" FontSize="16"
                                                Command="{Binding DataContext.OdebratRadekCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Krok 3 – souhrn -->
                <StackPanel Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Souhrn příjemky" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Doklad: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CisloDokladu}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Dodavatel: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Dodavatel}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Položek: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Radky.Count}"/>
                    </StackPanel>

                    <Border Background="#F0F6FF" CornerRadius="6" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Celkem bez DPH: " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CelkemBezDPH, StringFormat={}{0:N2} Kč}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Celkem s DPH:  " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CelkemSDPH, StringFormat={}{0:N2} Kč}" Foreground="#0066CC" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Zpět"
                    Command="{Binding ZpetCommand}"
                    Padding="14,8"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Další →"
                        Command="{Binding DalsiCommand}"
                        Padding="18,8" Background="#0078D4" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <Button Content="✓ Uložit příjemku"
                        Command="{Binding UlozitCommand}"
                        Padding="18,8" Background="#107C10" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
