<UserControl x:Class="Gastrox.Views.NaskladnitWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13" Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:NaskladnitWizardViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stepper -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Naskladnit zboží" FontSize="24" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="① Doklad" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="① Doklad" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}"/>
                <TextBlock Text="② Položky" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="② Položky" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}"/>
                <TextBlock Text="③ Souhrn" Foreground="#888"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="③ Souhrn" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="24">
            <Grid>
                <!-- Krok 1 – hlavička -->
                <StackPanel Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Údaje o dokladu" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Číslo dokladu"/>
                            <TextBox Text="{Binding CisloDokladu, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" Padding="8,6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Datum přijetí"/>
                            <DatePicker SelectedDate="{Binding DatumPrijeti}" Margin="0,4,0,12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Dodavatel"/>
                    <TextBox Text="{Binding Dodavatel, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" Padding="8,6"/>

                    <TextBlock Text="Číslo faktury / DL"/>
                    <TextBox Text="{Binding CisloFaktury, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" Padding="8,6"/>

                    <TextBlock Text="Poznámka"/>
                    <TextBox Text="{Binding Poznamka, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"
                             Padding="8,6" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Krok 2 – položky (kartová layout, čitelná pro provozního) -->
                <Grid Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Položky příjmu" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="+ Přidat položku" Command="{Binding PridatRadekCommand}"
                                Margin="16,0,0,0" Padding="14,8"
                                Background="#0078D4" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Radky}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FB" BorderBrush="#E1E5EA" BorderThickness="1"
                                            CornerRadius="10" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Řádek 1: Zboží + Balení -->
                                            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Zboží" Foreground="#666" FontSize="12"/>
                                                    <ComboBox ItemsSource="{Binding DataContext.DostupneZbozi,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              SelectedItem="{Binding VybraneZbozi, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="Nazev"
                                                              IsEditable="True" IsTextSearchEnabled="True"
                                                              TextSearch.TextPath="Nazev"
                                                              Margin="0,4,0,0" Padding="8,6" FontSize="14"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Balení" Foreground="#666" FontSize="12"/>
                                                    <Border Background="White" BorderBrush="#E1E5EA" BorderThickness="1"
                                                            CornerRadius="3" Padding="8,7" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding TypBaleni}" FontSize="14"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <!-- ✕ tlačítko v pravém horním rohu -->
                                            <Button Grid.Row="0" Grid.Column="1"
                                                    Content="✕" FontSize="14"
                                                    Width="32" Height="32"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Top"
                                                    Background="Transparent"
                                                    Foreground="#D13438"
                                                    BorderBrush="#E1E5EA" BorderThickness="1"
                                                    Cursor="Hand"
                                                    ToolTip="Odebrat položku"
                                                    Command="{Binding DataContext.OdebratRadekCommand,
                                                                       RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>

                                            <!-- Řádek 2: Počet balení / Cena / DPH -->
                                            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Počet balení" Foreground="#666" FontSize="12"/>
                                                    <TextBox Text="{Binding PocetBaleni, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                             Margin="0,4,0,0" Padding="8,7" FontSize="14"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Cena za balení (bez DPH)" Foreground="#666" FontSize="12"/>
                                                    <TextBox Text="{Binding NakupniCenaBezDPH, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                             Margin="0,4,0,0" Padding="8,7" FontSize="14"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="Sazba DPH" Foreground="#666" FontSize="12"/>
                                                    <ComboBox ItemsSource="{Binding DostupneSazby}"
                                                              SelectedItem="{Binding VybranaSazba, UpdateSourceTrigger=PropertyChanged}"
                                                              Margin="0,4,0,0" Padding="8,6" FontSize="14"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Řádek 3: Přepočet + Celkem -->
                                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="Přepočet: " Foreground="#666"/>
                                                    <TextBlock Text="{Binding ZobrazeniPrepoctu}"
                                                               Foreground="#0066CC" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="Celkem bez DPH: " Foreground="#666"/>
                                                    <TextBlock Text="{Binding CelkemBezDPH, StringFormat={}{0:N2} Kč}"
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Průběžný součet pod seznamem -->
                    <Border Grid.Row="2" Background="#F0F6FF" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Položek: " Foreground="#666"/>
                                <TextBlock Text="{Binding Radky.Count}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Mezisoučet bez DPH: " Foreground="#666"/>
                                <TextBlock Text="{Binding CelkemBezDPH, StringFormat={}{0:N2} Kč}" FontWeight="SemiBold" Margin="0,0,16,0"/>
                                <TextBlock Text="s DPH: " Foreground="#666"/>
                                <TextBlock Text="{Binding CelkemSDPH, StringFormat={}{0:N2} Kč}"
                                           Foreground="#0066CC" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Krok 3 – souhrn -->
                <StackPanel Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Souhrn příjemky" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Doklad: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CisloDokladu}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Dodavatel: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Dodavatel}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Položek: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Radky.Count}"/>
                    </StackPanel>

                    <Border Background="#F0F6FF" CornerRadius="6" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Celkem bez DPH: " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CelkemBezDPH, StringFormat={}{0:N2} Kč}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Celkem s DPH:  " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CelkemSDPH, StringFormat={}{0:N2} Kč}" Foreground="#0066CC" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Zpět"
                    Command="{Binding ZpetCommand}"
                    Padding="14,8"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Další →"
                        Command="{Binding DalsiCommand}"
                        Padding="18,8" Background="#0078D4" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <Button Content="✓ Uložit příjemku"
                        Command="{Binding UlozitCommand}"
                        Padding="18,8" Background="#107C10" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
