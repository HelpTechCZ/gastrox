<UserControl x:Class="Gastrox.Views.InventuraWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13" Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:InventuraWizardViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stepper -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Inventura" FontSize="24" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="① Nová inventura" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="① Nová inventura" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}"/>
                <TextBlock Text="② Fyzické stavy" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="② Fyzické stavy" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}"/>
                <TextBlock Text="③ Vyhodnocení" Foreground="#888"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="③ Vyhodnocení" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="24">
            <Grid>
                <!-- Krok 1 -->
                <StackPanel Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Začínáme novou inventuru" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Název"/>
                    <TextBox Text="{Binding Nazev, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,4,0,16" Padding="8,6"/>

                    <TextBlock Text="Datum"/>
                    <DatePicker SelectedDate="{Binding Datum}" Margin="0,4,0,16"/>

                    <TextBlock Text="Poznámka (nepovinná)"/>
                    <TextBox Text="{Binding Poznamka, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,4,0,0" Padding="8,6" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Krok 2 – fyzické stavy -->
                <Grid Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Zadejte fyzicky nasčítané množství u každé karty." Margin="0,0,0,8" Foreground="#666"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Radky}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeight="34">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Zboží" Binding="{Binding NazevZbozi}" IsReadOnly="True" Width="2*"
                                                CellStyle="{StaticResource ReadOnlyCellStyle}"/>
                            <DataGridTextColumn Header="EJ" Binding="{Binding EvidencniJednotka}" IsReadOnly="True" Width="60"
                                                CellStyle="{StaticResource ReadOnlyCellStyle}"/>
                            <DataGridTextColumn Header="Teoretický stav"
                                                Binding="{Binding TeoretickyStav, StringFormat=N2}"
                                                IsReadOnly="True" Width="*"
                                                CellStyle="{StaticResource ReadOnlyCellStyle}"/>
                            <DataGridTextColumn Header="Fyzický stav"
                                                Binding="{Binding FyzickyStav, StringFormat=N2}"
                                                EditingElementStyle="{StaticResource NumericTextBox}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Rozdíl"
                                                Binding="{Binding Rozdil, StringFormat=N2}"
                                                IsReadOnly="True" Width="*"
                                                CellStyle="{StaticResource ReadOnlyCellStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Krok 3 – vyhodnocení -->
                <StackPanel Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Vyhodnocení inventury" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Border Background="#FFF8E1" CornerRadius="6" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Položek s rozdílem: " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PocetSRozdilem}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Celkový rozdíl: " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CelkovyRozdil, StringFormat=N2}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Můžete inventuru uložit jako rozpracovanou (stavy se nezmění) nebo uzavřít – tím se přepíšou stavy podle fyzicky napočítaného množství."
                               TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Zpět"
                    Command="{Binding ZpetCommand}"
                    Padding="14,8"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Další →"
                        Command="{Binding DalsiCommand}"
                        Padding="18,8" Background="#0078D4" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        ClickMode="Press"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <Button Content="Uložit rozpracovanou"
                        Command="{Binding UlozitRozpracovanouCommand}"
                        Padding="14,8"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
                <Button Content="✓ Uzavřít a srovnat stavy"
                        Command="{Binding UzavritCommand}"
                        Margin="8,0,0,0"
                        Padding="18,8" Background="#107C10" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
