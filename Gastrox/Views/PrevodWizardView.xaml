<UserControl x:Class="Gastrox.Views.PrevodWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13" Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:PrevodWizardViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stepper -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Převod mezi sklady" FontSize="24" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="① Sklady" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="① Sklady" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}"/>

                <TextBlock Text="② Položky" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="② Položky" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}"/>

                <TextBlock Text="③ Souhrn" Foreground="#888"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="③ Souhrn" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </StackPanel>

        <!-- Obsah -->
        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="24">
            <Grid>
                <!-- Krok 1 -->
                <StackPanel Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Odkud a kam" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Číslo dokladu"/>
                            <TextBox Text="{Binding CisloDokladu, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,12" Padding="8,6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Datum převodu"/>
                            <DatePicker SelectedDate="{Binding DatumPrevodu}" Margin="0,4,0,12"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Zdrojový sklad"/>
                            <ComboBox ItemsSource="{Binding Sklady}" SelectedItem="{Binding SkladZdroj}"
                                      DisplayMemberPath="Nazev"
                                      Margin="0,4,0,12" Padding="8,6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Cílový sklad"/>
                            <ComboBox ItemsSource="{Binding Sklady}" SelectedItem="{Binding SkladCil}"
                                      DisplayMemberPath="Nazev"
                                      Margin="0,4,0,12" Padding="8,6"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Poznámka (nepovinná)"/>
                    <TextBox Text="{Binding Poznamka, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,4,0,0" Padding="8,6" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Krok 2 -->
                <Grid Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Položky převodu" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="+ Přidat řádek"
                                Command="{Binding PridatRadekCommand}"
                                Margin="16,0,0,0" Padding="10,6"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Radky}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Zboží" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.DostupneZbozi,
                                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding VybraneZbozi, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Nazev"
                                                  IsEditable="True" IsTextSearchEnabled="True"
                                                  TextSearch.TextPath="Nazev"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Stav ve zdroji"
                                                Binding="{Binding StavNaSkladu, StringFormat=N2}"
                                                IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="EJ"
                                                Binding="{Binding EvidencniJednotka}"
                                                IsReadOnly="True" Width="60"/>
                            <DataGridTextColumn Header="Množství k převodu"
                                                Binding="{Binding MnozstviEvidencni, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                EditingElementStyle="{StaticResource NumericTextBox}"
                                                Width="*"/>

                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="×" FontSize="16"
                                                Command="{Binding DataContext.OdebratRadekCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Krok 3 -->
                <StackPanel Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Souhrn převodu" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Doklad: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CisloDokladu}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Z: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SkladZdroj.Nazev}"/>
                        <TextBlock Text="  →  "/>
                        <TextBlock Text="Do: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SkladCil.Nazev}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Položek: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Radky.Count}"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Radky}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F8F8" Padding="10" Margin="0,0,0,4" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding VybraneZbozi.Nazev}" FontWeight="SemiBold" Width="280"/>
                                        <TextBlock Text="{Binding MnozstviEvidencni, StringFormat=N2}"/>
                                        <TextBlock Text=" "/>
                                        <TextBlock Text="{Binding EvidencniJednotka}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Zpět"
                    Command="{Binding ZpetCommand}"
                    Padding="14,8"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Další →"
                        Command="{Binding DalsiCommand}"
                        Padding="18,8" Background="#0078D4" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <Button Content="✓ Uložit převodku"
                        Command="{Binding UlozitCommand}"
                        Padding="18,8" Background="#107C10" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
