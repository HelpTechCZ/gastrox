<UserControl x:Class="Gastrox.Views.MarzeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13" Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:MarzeViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Marže za období" FontSize="24" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="Od:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding Od}" Width="140"/>
                <TextBlock Text="Do:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <DatePicker SelectedDate="{Binding Do}" Width="140"/>
                <Button Content="Export Excel"
                        Command="{Binding ExportExcelCommand}"
                        Margin="24,0,0,0" Padding="14,8"
                        Background="#107C10" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>

        <!-- Tabulka -->
        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="4">
            <DataGrid ItemsSource="{Binding Radky}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="36">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Zboží" Binding="{Binding Nazev}" Width="2*"/>
                    <DataGridTextColumn Header="Kategorie" Binding="{Binding Kategorie}" Width="*"/>
                    <DataGridTextColumn Header="Množství" Binding="{Binding Mnozstvi, StringFormat=N2}" Width="90"
                                        ElementStyle="{StaticResource NumericCell}"/>
                    <DataGridTextColumn Header="EJ" Binding="{Binding EvidencniJednotka}" Width="50"/>
                    <DataGridTextColumn Header="Nákup bez DPH" Binding="{Binding NakupBezDPH, StringFormat=N2}" Width="110"
                                        ElementStyle="{StaticResource NumericCell}"/>
                    <DataGridTextColumn Header="Prodej bez DPH" Binding="{Binding ProdejBezDPH, StringFormat=N2}" Width="110"
                                        ElementStyle="{StaticResource NumericCell}"/>
                    <DataGridTextColumn Header="Marže Kč" Binding="{Binding MarzeKc, StringFormat=N2}" Width="90"
                                        ElementStyle="{StaticResource NumericCell}"/>
                    <DataGridTextColumn Header="Marže %" Binding="{Binding MarzeProcent, StringFormat=N1}" Width="70"
                                        ElementStyle="{StaticResource NumericCell}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F0F6FF" CornerRadius="8" Padding="16" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Položek: " Foreground="#666"/>
                    <TextBlock Text="{Binding Radky.Count}" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Nákup: " Foreground="#666"/>
                    <TextBlock Text="{Binding CelkemNakupBezDPH, StringFormat={}{0:N2} Kč}" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Prodej: " Foreground="#666"/>
                    <TextBlock Text="{Binding CelkemProdejBezDPH, StringFormat={}{0:N2} Kč}" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <TextBlock Text="Marže: " Foreground="#666"/>
                    <TextBlock FontWeight="Bold" Foreground="#0066CC">
                        <Run Text="{Binding CelkemMarzeKc, StringFormat=N2, Mode=OneWay}"/>
                        <Run Text=" Kč ("/>
                        <Run Text="{Binding CelkemMarzeProcent, StringFormat=N1, Mode=OneWay}"/>
                        <Run Text=" %)"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
