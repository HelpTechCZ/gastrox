<UserControl x:Class="Gastrox.Views.VydejkaWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13" Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:VydejkaWizardViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stepper -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Vyskladnit zboží" FontSize="24" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="① Typ výdeje" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="① Typ výdeje" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}"/>

                <TextBlock Text="② Položky" Margin="0,0,18,0" Foreground="#888"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="② Položky" Margin="0,0,18,0" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}"/>

                <TextBlock Text="③ Souhrn" Foreground="#888"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <TextBlock Text="③ Souhrn" FontWeight="Bold" Foreground="#0078D4"
                           Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </StackPanel>

        <!-- Obsah -->
        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="24">
            <Grid>
                <!-- Krok 1 -->
                <StackPanel Visibility="{Binding JeKrok1, Converter={StaticResource BoolToVisConv}}">
                    <!-- Rozpracované doklady -->
                    <Border Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="1"
                            CornerRadius="8" Padding="14" Margin="0,0,0,16"
                            Visibility="{Binding MaRozpracovane, Converter={StaticResource BoolToVisConv}}">
                        <StackPanel>
                            <TextBlock Text="Rozpracované výdejky" FontWeight="SemiBold" Foreground="#7B6B00" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Rozpracovane}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Nazev}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Upraveno, StringFormat='Uloženo: {0:d. M. yyyy H:mm}'}"
                                                               Foreground="#888" FontSize="11"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Pokračovat"
                                                        Command="{Binding DataContext.PokracovatVRozpracovanemCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="12,6" Margin="8,0,0,0"
                                                        Background="#0078D4" Foreground="White"
                                                        BorderThickness="0" Cursor="Hand"/>
                                                <Button Grid.Column="2" Content="Smazat"
                                                        Command="{Binding DataContext.SmazatRozpracovaneCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="12,6" Margin="8,0,0,0"
                                                        Foreground="#D13438" Background="Transparent"
                                                        BorderBrush="#D13438" BorderThickness="1" Cursor="Hand"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Co je to za výdej?" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Zdrojový sklad"/>
                    <ComboBox ItemsSource="{Binding Sklady}" SelectedItem="{Binding VybranySklad}"
                              DisplayMemberPath="Nazev"
                              Margin="0,4,0,16" Padding="8,6"/>

                    <TextBlock Text="Typ výdeje"/>
                    <ComboBox ItemsSource="{Binding TypyVydeje}" SelectedItem="{Binding TypVydeje}"
                              Margin="0,4,0,16" Padding="8,6"/>

                    <TextBlock Text="Středisko"/>
                    <ComboBox ItemsSource="{Binding Strediska}" SelectedItem="{Binding Stredisko}"
                              Margin="0,4,0,16" Padding="8,6"/>

                    <TextBlock Text="Poznámka (nepovinná)"/>
                    <TextBox Text="{Binding Poznamka, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,4,0,0" Padding="8,6" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Krok 2 -->
                <Grid Visibility="{Binding JeKrok2, Converter={StaticResource BoolToVisConv}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Položky výdeje" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="+ Přidat řádek"
                                Command="{Binding PridatRadekCommand}"
                                Margin="16,0,0,0" Padding="10,6"/>
                    </StackPanel>

                    <DataGrid x:Name="GridPolozky" Grid.Row="1"
                              ItemsSource="{Binding Radky}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Zboží" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.DostupneZbozi,
                                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding VybraneZbozi, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Nazev"
                                                  IsEditable="True" IsTextSearchEnabled="True"
                                                  TextSearch.TextPath="Nazev"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Stav"
                                                Binding="{Binding StavNaSkladu, StringFormat=N2}"
                                                IsReadOnly="True" Width="*"
                                                CellStyle="{StaticResource ReadOnlyCellStyle}"/>
                            <DataGridTextColumn Header="EJ"
                                                Binding="{Binding EvidencniJednotka}"
                                                IsReadOnly="True" Width="60"
                                                CellStyle="{StaticResource ReadOnlyCellStyle}"/>
                            <DataGridTextColumn Header="Množství k výdeji"
                                                Binding="{Binding MnozstviEvidencni, StringFormat=N2}"
                                                EditingElementStyle="{StaticResource NumericTextBox}"
                                                Width="*"/>

                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="×" FontSize="16"
                                                Command="{Binding DataContext.OdebratRadekCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Krok 3 -->
                <StackPanel Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="Souhrn výdeje" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Sklad: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding VybranySklad.Nazev}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Typ: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TypVydeje}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Středisko: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Stredisko}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Položek: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Radky.Count}"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Radky}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F8F8" Padding="10" Margin="0,0,0,4" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding VybraneZbozi.Nazev}" FontWeight="SemiBold"/>
                                            <TextBlock Text="  " />
                                            <TextBlock Text="{Binding MnozstviEvidencni, StringFormat=N2}"/>
                                            <TextBlock Text=" "/>
                                            <TextBlock Text="{Binding EvidencniJednotka}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Margin="12,0,0,0" Foreground="#666">
                                            <Run Text="N: "/>
                                            <Run Text="{Binding HodnotaNakupBezDPH, StringFormat=N2, Mode=OneWay}"/>
                                            <Run Text=" Kč"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Margin="12,0,0,0" Foreground="#0066CC">
                                            <Run Text="P: "/>
                                            <Run Text="{Binding HodnotaProdejSDPH, StringFormat=N2, Mode=OneWay}"/>
                                            <Run Text=" Kč"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Cenový souhrn -->
                    <Border Background="#F0F6FF" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Nákupní ceny -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nákupní ceny" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="Bez DPH: " Foreground="#666" Width="70"/>
                                    <TextBlock Text="{Binding CelkemNakupBezDPH, StringFormat={}{0:N2} Kč}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="S DPH: " Foreground="#666" Width="70"/>
                                    <TextBlock Text="{Binding CelkemNakupSDPH, StringFormat={}{0:N2} Kč}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Prodejní ceny -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Prodejní ceny" FontWeight="SemiBold" Foreground="#0066CC" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="Bez DPH: " Foreground="#666" Width="70"/>
                                    <TextBlock Text="{Binding CelkemProdejBezDPH, StringFormat={}{0:N2} Kč}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="S DPH: " Foreground="#666" Width="70"/>
                                    <TextBlock Text="{Binding CelkemProdejSDPH, StringFormat={}{0:N2} Kč}"
                                               FontWeight="Bold" Foreground="#0066CC"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer s navigací -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="← Zpět"
                        Command="{Binding ZpetCommand}"
                        Padding="14,8"/>
                <Button Content="Uložit rozpracované"
                        Command="{Binding UlozitRozpracovaneCommand}"
                        Padding="14,8" Margin="8,0,0,0"
                        Foreground="#7B6B00" Background="#FFF8E1"
                        BorderBrush="#FFD54F" BorderThickness="1" Cursor="Hand"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Další →"
                        Command="{Binding DalsiCommand}"
                        Padding="18,8" Background="#0078D4" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        ClickMode="Press"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToInverseVisConv}}"/>
                <Button Content="✓ Uložit výdejku"
                        Command="{Binding UlozitCommand}"
                        Padding="18,8" Background="#107C10" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        ClickMode="Press"
                        Visibility="{Binding JeKrok3, Converter={StaticResource BoolToVisConv}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
