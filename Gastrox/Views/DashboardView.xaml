<UserControl x:Class="Gastrox.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             FontFamily="Segoe UI" FontSize="13"
             Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="ActionTile" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="14" Padding="28">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Hlavička -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{Binding Pozdrav}" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding DnesniDatum}" Foreground="#777" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Velké akční dlaždice -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnNaskladnit" Grid.Column="0" Style="{StaticResource ActionTile}"
                        Click="Naskladnit_Click" Height="180">
                    <StackPanel>
                        <TextBlock Text="📥" FontSize="48"/>
                        <TextBlock Text="Naskladnit" FontSize="22" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        <TextBlock Text="Příjem zboží od dodavatele" Foreground="#666" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnVyskladnit" Grid.Column="2" Style="{StaticResource ActionTile}"
                        Click="Vyskladnit_Click" Height="180">
                    <StackPanel>
                        <TextBlock Text="📤" FontSize="48"/>
                        <TextBlock Text="Vyskladnit" FontSize="22" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        <TextBlock Text="Prodej, spotřeba, odpis" Foreground="#666" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnInventura" Grid.Column="4" Style="{StaticResource ActionTile}"
                        Click="Inventura_Click" Height="180">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="48"/>
                        <TextBlock Text="Inventura" FontSize="22" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        <TextBlock Text="Fyzická kontrola stavů" Foreground="#666" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnNovaKarta" Grid.Column="6" Style="{StaticResource ActionTile}"
                        Click="NovaKarta_Click" Height="180">
                    <StackPanel>
                        <TextBlock Text="➕" FontSize="48"/>
                        <TextBlock Text="Nová karta" FontSize="22" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        <TextBlock Text="Založit novou skladovou kartu" Foreground="#666" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Hodnota skladových zásob -->
            <Border Background="White" CornerRadius="14" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="💰 Hodnota skladových zásob" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F5F9FF" CornerRadius="10" Padding="16">
                            <StackPanel>
                                <TextBlock Text="NÁKUP" Foreground="#666" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="bez DPH" Foreground="#888" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding HodnotaNakupBezDph, StringFormat={}{0:N2} Kč}"
                                           FontSize="22" FontWeight="Bold" Foreground="#0078D4"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#F5F9FF" CornerRadius="10" Padding="16">
                            <StackPanel>
                                <TextBlock Text="NÁKUP" Foreground="#666" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="s DPH" Foreground="#888" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding HodnotaNakupSDph, StringFormat={}{0:N2} Kč}"
                                           FontSize="22" FontWeight="Bold" Foreground="#0078D4"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="#F4FBF4" CornerRadius="10" Padding="16">
                            <StackPanel>
                                <TextBlock Text="PRODEJ" Foreground="#666" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="bez DPH" Foreground="#888" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding HodnotaProdejBezDph, StringFormat={}{0:N2} Kč}"
                                           FontSize="22" FontWeight="Bold" Foreground="#107C10"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" Background="#F4FBF4" CornerRadius="10" Padding="16">
                            <StackPanel>
                                <TextBlock Text="PRODEJ" Foreground="#666" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="s DPH" Foreground="#888" FontSize="11" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding HodnotaProdejSDph, StringFormat={}{0:N2} Kč}"
                                           FontSize="22" FontWeight="Bold" Foreground="#107C10"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Dva sloupce – Pod limitem + Statistika -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Pod limitem -->
                <Border Grid.Column="0" Background="White" CornerRadius="14" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="⚠️ Pod limitem" FontSize="18" FontWeight="SemiBold"/>
                            <Border Background="#D13438" CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding MaPodLimitem, Converter={StaticResource BoolToVisConv}, FallbackValue=Collapsed}">
                                <TextBlock Text="{Binding PocetPodLimitem}" Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding KartyPodLimitem}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF4F4" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Nazev}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Kategorie}" Foreground="#888" FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding AktualniStavEvidencni, StringFormat=N2}"/>
                                                    <TextBlock Text=" "/>
                                                    <TextBlock Text="{Binding EvidencniJednotka}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding MinimalniStav, StringFormat='limit {0:N2}'}"
                                                           Foreground="#888" FontSize="11" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Žádné položky pod limitem 🎉"
                                   Foreground="#888" Margin="0,8,0,0"
                                   Visibility="{Binding MaPodLimitem, Converter={StaticResource BoolToInverseVisConv}, FallbackValue=Visible}"/>
                    </StackPanel>
                </Border>

                <!-- Statistika -->
                <Border Grid.Column="2" Background="White" CornerRadius="14" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📊 Posledních 7 dní" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding PohybyZaTyden}" FontSize="40" FontWeight="Bold" Foreground="#0078D4"/>
                        <TextBlock Text="pohybů na skladě" Foreground="#666"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
