<UserControl x:Class="Gastrox.Views.SkladView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gastrox.ViewModels"
             xmlns:dgp="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             FontFamily="Segoe UI" FontSize="13"
             Background="#F3F3F3">
    <UserControl.DataContext>
        <vm:SkladViewModel />
    </UserControl.DataContext>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hlavička -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Sklad" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="+ Nová karta"
                    Command="{Binding NovaKartaCommand}"
                    Margin="24,0,0,0" Padding="14,8" Background="#0078D4" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- Seznam karet (s filtrem nahoře) -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="0" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filtr panel -->
                    <Grid Grid.Row="0" Margin="12,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding HledanyText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6"
                                 ToolTip="Hledat v názvu nebo EAN"
                                 VerticalContentAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="placeholder" TileMode="None" Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍 Hledat (název nebo EAN)…" Foreground="#999" Margin="4,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource placeholder}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding KategorieFiltr}"
                                  SelectedItem="{Binding VybranaFiltrKategorie}"
                                  Padding="8,6"
                                  ToolTip="Filtr kategorie"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding KartyView}"
                              SelectedItem="{Binding VybranaKarta}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="32"
                              ColumnHeaderHeight="44"
                              AlternatingRowBackground="#FAFAFA">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type dgp:DataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Resources>
                            <!-- ElementStyle pro TEXT buňky (Název, Kategorie, EJ) – zarovnání VLEVO.
                                 POZOR: implicit styl v DataGrid.Resources se NEAPLIKUJE na cells
                                 DataGridTextColumn – WPF je generuje mimo logical tree. Proto
                                 musí být explicit pojmenovaný styl aplikovaný přes ElementStyle. -->
                            <Style x:Key="CellText" TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextAlignment" Value="Left"/>
                                <Setter Property="Margin" Value="2,0,0,0"/>
                            </Style>
                            <!-- ElementStyle pro NUMERICKÉ buňky – zarovnání VPRAVO. -->
                            <Style x:Key="NumericCell" TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                            <!-- Header styl pro numerické sloupce – zarovnání VPRAVO. -->
                            <Style x:Key="NumericHeader" TargetType="{x:Type dgp:DataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,4,8,4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Název"     Binding="{Binding Nazev}"            Width="*" MinWidth="140"
                                                ElementStyle="{StaticResource CellText}"/>
                            <DataGridTextColumn Header="Kategorie" Binding="{Binding Kategorie}"        Width="110"
                                                ElementStyle="{StaticResource CellText}"/>
                            <DataGridTextColumn Binding="{Binding StavSJednotkou}"
                                                Width="100"
                                                ElementStyle="{StaticResource NumericCell}"
                                                HeaderStyle="{StaticResource NumericHeader}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="Stav" TextAlignment="Right"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding MinimalniStavSJednotkou}"
                                                Width="90"
                                                ElementStyle="{StaticResource NumericCell}"
                                                HeaderStyle="{StaticResource NumericHeader}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="Min." TextAlignment="Right"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding NakupniCenaZaJednotkuBezDPH, StringFormat=N2}"
                                                Width="100"
                                                ElementStyle="{StaticResource NumericCell}"
                                                HeaderStyle="{StaticResource NumericHeader}">
                                <DataGridTextColumn.Header>
                                    <TextBlock TextAlignment="Right">Nákup za j.<LineBreak/>bez DPH</TextBlock>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding HodnotaNakupBezDPH, StringFormat=N2}"
                                                Width="120"
                                                ElementStyle="{StaticResource NumericCell}"
                                                HeaderStyle="{StaticResource NumericHeader}">
                                <DataGridTextColumn.Header>
                                    <TextBlock TextAlignment="Right">Nákup celkem<LineBreak/>bez DPH</TextBlock>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding ProdejniCenaZaJednotkuSDPH, StringFormat=N2}"
                                                Width="100"
                                                ElementStyle="{StaticResource NumericCell}"
                                                HeaderStyle="{StaticResource NumericHeader}">
                                <DataGridTextColumn.Header>
                                    <TextBlock TextAlignment="Right">Prodej za j.<LineBreak/>s DPH</TextBlock>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding HodnotaProdejSDPH, StringFormat=N2}"
                                                Width="120"
                                                ElementStyle="{StaticResource NumericCell}"
                                                HeaderStyle="{StaticResource NumericHeader}">
                                <DataGridTextColumn.Header>
                                    <TextBlock TextAlignment="Right">Prodej celkem<LineBreak/>s DPH</TextBlock>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Formulář -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Karta" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <TextBlock Text="Název *"/>
                        <TextBox Text="{Binding Nazev, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="6,4"/>

                        <TextBlock Text="Kategorie"/>
                        <ComboBox ItemsSource="{Binding Kategorie}"
                                  DisplayMemberPath="Nazev"
                                  SelectedValuePath="Nazev"
                                  SelectedValue="{Binding Kategorie_Sel}"
                                  Margin="0,2,0,10" Padding="6,4"/>

                        <TextBlock Text="EAN"/>
                        <TextBox Text="{Binding EAN, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="6,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Evidenční jednotka"/>
                                <ComboBox ItemsSource="{Binding EvidencniJednotky}"
                                          SelectedItem="{Binding EvidencniJednotka_Sel}"
                                          Margin="0,2,0,10" Padding="6,4"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Koeficient"/>
                                <TextBox Text="{Binding KoeficientPrepoctu, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Margin="0,2,0,10" Padding="6,4"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Typ balení (Láhev 0,7l, Sud 50l, …)"/>
                        <TextBox Text="{Binding TypBaleni, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="6,4"/>

                        <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="0,6,0,12"/>

                        <TextBlock Text="Ceny" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <TextBlock Text="Sazba DPH"/>
                        <ComboBox ItemsSource="{Binding DostupneSazby}"
                                  SelectedItem="{Binding VybranaSazba}"
                                  Margin="0,2,0,10" Padding="6,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nákupní cena bez DPH"/>
                                <TextBox Text="{Binding NakupniCenaBezDPH, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Margin="0,2,0,4" Padding="6,4"/>
                                <TextBlock Foreground="#666"
                                           Text="{Binding NakupniCenaSDPH, StringFormat='s DPH: {0:N2} Kč'}"
                                           Margin="0,0,0,10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Prodejní cena s DPH"/>
                                <TextBox Text="{Binding ProdejniCenaSDPH, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Margin="0,2,0,4" Padding="6,4"/>
                                <TextBlock Foreground="#666"
                                           Text="{Binding ProdejniCenaBezDPH, StringFormat='bez DPH: {0:N2} Kč'}"
                                           Margin="0,0,0,10"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#FFF8E1" CornerRadius="6" Padding="10" Margin="0,4,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Marže: " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding MarzeKc, StringFormat=N2}"/>
                                <TextBlock Text=" Kč  ("/>
                                <TextBlock Text="{Binding MarzeProcent, StringFormat=N1}"/>
                                <TextBlock Text=" %)"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="0,6,0,12"/>

                        <TextBlock Text="Minimální stav (limit pro objednání)"/>
                        <TextBox Text="{Binding MinimalniStav, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Margin="0,2,0,10" Padding="6,4"/>

                        <TextBlock Text="Dodavatel"/>
                        <TextBox Text="{Binding Dodavatel, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,16" Padding="6,4"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Uložit"
                                    Command="{Binding UlozitCommand}"
                                    Padding="14,8" Background="#0078D4" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
                            <Button Content="Deaktivovat"
                                    Command="{Binding DeaktivovatCommand}"
                                    Margin="8,0,0,0" Padding="14,8" Background="#D13438" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>

                        <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="0,16,0,12"/>

                        <TextBlock Text="Pohyby na kartě" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Text="Vyberte kartu v seznamu pro zobrazení historie pohybů."
                                   Foreground="#888"
                                   Visibility="{Binding MaPohyby, Converter={StaticResource BoolToInverseVisConv}}"/>

                        <DataGrid ItemsSource="{Binding Pohyby}"
                                  Visibility="{Binding MaPohyby, Converter={StaticResource BoolToVisConv}}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  RowHeight="28"
                                  MaxHeight="320"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Datum"   Binding="{Binding Datum, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="120"/>
                                <DataGridTextColumn Header="Typ"     Binding="{Binding TypPohybuLabel}" Width="80"/>
                                <DataGridTextColumn Header="Množ."   Binding="{Binding MnozstviText}"   Width="70"/>
                                <DataGridTextColumn Header="Stav po" Binding="{Binding StavPoPohybu, StringFormat=N2}" Width="70"/>
                                <DataGridTextColumn Header="Doklad"  Binding="{Binding DokladTyp}"      Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
